// Collaborative Team Hub — Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  avatarUrl    String?
  refreshToken String?
  isVerified   Boolean  @default(false)
  verificationToken String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     WorkspaceMember[]
  ownedGoals      Goal[]            @relation("GoalOwner")
  assignedActions ActionItem[]      @relation("ActionAssignee")
  announcements   Announcement[]
  comments        Comment[]
  reactions       Reaction[]
  activities      Activity[]
  mentions        Mention[]
  auditLogs       AuditLog[]
}

// ─── Workspace ───────────────────────────────────────────────────
model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  accentColor String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       WorkspaceMember[]
  goals         Goal[]
  announcements Announcement[]
  actionItems   ActionItem[]
  activities    Activity[]
  auditLogs     AuditLog[]
}

// ─── WorkspaceMember (join table with role) ──────────────────────
enum Role {
  ADMIN
  MEMBER
}

model WorkspaceMember {
  id        String   @id @default(cuid())
  role      Role     @default(MEMBER)
  joinedAt  DateTime @default(now())

  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// ─── Goal ────────────────────────────────────────────────────────
enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      GoalStatus @default(NOT_STARTED)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  ownerId     String
  workspaceId String
  owner       User       @relation("GoalOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  milestones  Milestone[]
  actionItems ActionItem[]
  activities  Activity[]
}

// ─── Milestone ───────────────────────────────────────────────────
model Milestone {
  id              String   @id @default(cuid())
  title           String
  completed       Boolean  @default(false)
  progressPercent Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  goalId String
  goal   Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

// ─── Announcement ────────────────────────────────────────────────
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String   // rich-text HTML
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId    String
  workspaceId String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  comments  Comment[]
  reactions Reaction[]
}

// ─── Comment ─────────────────────────────────────────────────────
model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId       String
  announcementId String
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  mentions Mention[]
}

// ─── Reaction ────────────────────────────────────────────────────
model Reaction {
  id    String @id @default(cuid())
  emoji String // e.g. "👍", "🎉"

  userId         String
  announcementId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId, emoji])
}

// ─── ActionItem ──────────────────────────────────────────────────
enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActionStatus {
  TODO
  IN_PROGRESS
  DONE
}

model ActionItem {
  id        String       @id @default(cuid())
  title     String
  priority  Priority     @default(MEDIUM)
  status    ActionStatus @default(TODO)
  dueDate   DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  assigneeId  String?
  workspaceId String
  goalId      String?
  assignee    User?     @relation("ActionAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  goal        Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
}

// ─── Activity (feed) ─────────────────────────────────────────────
model Activity {
  id        String   @id @default(cuid())
  type      String   // e.g. "GOAL_CREATED", "STATUS_CHANGED", "COMMENT_ADDED"
  message   String
  meta      Json?    // optional metadata
  createdAt DateTime @default(now())

  userId      String
  workspaceId String
  goalId      String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  goal        Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
}

// ─── Mention ─────────────────────────────────────────────────────
model Mention {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  commentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

// ─── AuditLog ────────────────────────────────────────────────────
model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  action      String    // CREATE_GOAL, UPDATE_TASK, etc.
  entityType  String    // GOAL, ACTION_ITEM, ANNOUNCEMENT
  entityId    String
  details     Json?     // Old vs New values
  createdAt   DateTime  @default(now())
}
